# ===================================================================
# IMS Backend – Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env to git.
# ===================================================================

# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # development | production

# ── JWT ───────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_STRONG_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d
# JWT_TTL_MS is used for blacklist cleanup (default: 7 days in ms)
JWT_TTL_MS=604800000

# ── Database ──────────────────────────────────────────────────────
# Option A: Provide a full connection URL (Render/Railway/Supabase auto-sets this)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option B: Individual vars (used if DATABASE_URL is absent)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ims_db
DB_USER=postgres
DB_PASS=REPLACE_WITH_STRONG_PASSWORD
# DB_LOGGING=true   # Uncomment to enable SQL logging in development

# ── SMTP / Email ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false              # true for port 465, false for 587
SMTP_USER=your-email@gmail.com
# Use an App Password, NOT your actual Gmail password
# https://myaccount.google.com/apppasswords
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your-email@gmail.com

# ── Frontend URL (for CORS + password reset links) ────────────────
FRONTEND_URL=http://localhost:3759   # e.g. https://ims.yourdomain.com in prod

# ── Email recipients (notification targets) ───────────────────────
COE_CS_HEAD_EMAIL=head.coecs@nfsu.ac.in
DEAN_EMAIL=dean@nfsu.ac.in
ASSOCIATE_DEAN_EMAIL=associate.dean@nfsu.ac.in
SUPER_ADMIN_EMAIL=superadmin@nfsu.ac.in

# ── Admin seeding (used ONLY by scripts/seedAdmin.js) ────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ADMIN_EMAIL=admin@nfsu.ac.in
ADMIN_FULL_NAME=System Administrator

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=info   # error | warn | info | debug
