# ===================================================================
# IMS Frontend – Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env to git.
# All vars MUST start with REACT_APP_ to be available in the browser.
# ===================================================================

# URL of your backend API (no trailing slash)
# Development: http://localhost:5000
# Production:  https://ims-api.onrender.com  (or your backend URL)
REACT_APP_API_URL=http://localhost:5000

# Development server port
PORT=3759
